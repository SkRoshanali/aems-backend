# Database URL - PostgreSQL format (not JDBC)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://aems_user:aems_password@postgres:5432/aems_db

# For Neon (cloud PostgreSQL):
# DATABASE_URL=postgresql://neon_user:neon_password@ep-xxx.neon.tech/dbname?sslmode=require

# Google Generative AI (Gemini) Configuration
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_EMBEDDING_MODEL=embedding-001
GOOGLE_CHAT_MODEL=gemini-2.5-flash

# RAG Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
SEARCH_TOP_K=5

# Service Configuration
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO

# Internal service authentication (should match Spring Boot config)
INTERNAL_SECRET=your-internal-secret-key-change-this-in-production
